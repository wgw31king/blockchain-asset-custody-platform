{
  "info": {
    "name": "BACP API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Starter requests for Blockchain Asset Custody Platform (adjust base URL and bearer tokens)."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth — Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/login"
      }
    },
    {
      "name": "Auth — Me",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/auth/me"
      }
    },
    {
      "name": "Admin — Permissions page",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/admin/permissions?current=1&size=20"
      }
    },
    {
      "name": "Admin — Operation logs page",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/admin/operation-logs?current=1&size=20"
      }
    },
    {
      "name": "Actuator — Prometheus",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/actuator/prometheus"
      }
    }
  ]
}
