{
  "uid": "bacp-api",
  "title": "BACP / HTTP API",
  "tags": ["bacp", "http"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "annotations": {"list": []},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate by status",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "bacp-prom"},
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 12, "lineWidth": 1}},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP 4xx / 5xx rate",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "bacp-prom"},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"4..\"}[5m]))",
          "legendFormat": "4xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 1}},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP latency p50 / p95 / p99",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "bacp-prom"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 8, "lineWidth": 1}},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Top URIs by request rate",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 9},
      "datasource": {"type": "prometheus", "uid": "bacp-prom"},
      "targets": [
        {
          "expr": "topk(8, sum by (uri, method) (rate(http_server_requests_seconds_count[5m])))",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1}},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "bacp_api_errors_total (rate)",
      "description": "Micrometer counter from GlobalExceptionHandler — optional / confirms handler path.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
      "datasource": {"type": "prometheus", "uid": "bacp-prom"},
      "targets": [
        {
          "expr": "rate(bacp_api_errors_total[5m])",
          "legendFormat": "errors/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "line", "fillOpacity": 25, "lineWidth": 1}},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "HTTP outcomes (share over 5m)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "datasource": {"type": "prometheus", "uid": "bacp-prom"},
      "targets": [
        {
          "expr": "sum by (outcome) (increase(http_server_requests_seconds_count[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "min": 0, "displayName": ""},
        "overrides": []
      },
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    }
  ]
}
