{
  "uid": "bacp-jvm",
  "title": "BACP / JVM",
  "tags": ["bacp", "jvm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "annotations": {"list": []},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "JVM heap used (by pool)",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "bacp-prom"},
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 15, "lineWidth": 1, "spanNulls": false}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "JVM heap max (by pool)",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "bacp-prom"},
      "targets": [
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\"}",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "JVM non-heap used",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "bacp-prom"},
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"nonheap\"}",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"drawStyle": "line", "fillOpacity": 12, "lineWidth": 1}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GC pause time (rate)",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 9},
      "datasource": {"type": "prometheus", "uid": "bacp-prom"},
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum[5m])",
          "legendFormat": "{{action}} / {{cause}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s/s",
          "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 1}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "GC collections (rate)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
      "datasource": {"type": "prometheus", "uid": "bacp-prom"},
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count[5m])",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Classes loaded / buffer pools",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "datasource": {"type": "prometheus", "uid": "bacp-prom"},
      "targets": [
        {
          "expr": "jvm_classes_loaded_classes",
          "legendFormat": "loaded",
          "refId": "A"
        },
        {
          "expr": "jvm_buffer_memory_used_bytes",
          "legendFormat": "buffer {{id}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1},
          "unit": "short"
        },
        "overrides": [
          {"matcher": {"id": "byFrameRefId", "options": "B"}, "properties": [{"id": "unit", "value": "bytes"}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    }
  ]
}
