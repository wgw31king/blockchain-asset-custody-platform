      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 52
      },
      "datasource": {
        "type": "prometheus",
        "uid": "bacp-prom"
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"nonheap\"}",
