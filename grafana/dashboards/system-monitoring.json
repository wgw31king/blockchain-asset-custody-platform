        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 35,
      "type": "timeseries",
      "title": "Classes loaded / buffer pools",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 61
      },
      "datasource": {
        "type": "prometheus",
        "uid": "bacp-prom"
      },
      "targets": [
        {
          "expr": "jvm_classes_loaded_classes",
          "legendFormat": "loaded",
          "refId": "A"
        },
        {
          "expr": "jvm_buffer_memory_used_bytes",
          "legendFormat": "buffer {{id}}",
          "refId": "B"
