{
  "uid": "bacp-system-monitoring",
  "title": "BACP / System monitoring (OS, JVM, disk, network)",
  "tags": [
    "bacp",
    "system",
    "jvm"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "annotations": {
    "list": []
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Process CPU usage",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "bacp-prom"
      },
      "targets": [
        {
          "expr": "process_cpu_usage",
          "legendFormat": "process",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "System CPU usage",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "bacp-prom"
      },
      "targets": [
        {
          "expr": "system_cpu_usage",
          "legendFormat": "system",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.75
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdMarkers": true
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Process uptime",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "bacp-prom"
      },
      "targets": [
        {
          "expr": "process_uptime_seconds",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Process resident memory",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "bacp-prom"
      },
      "targets": [
        {
          "expr": "process_memory_usage_bytes",
          "legendFormat": "RSS / JVM reported",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM memory total (heap + nonheap used)",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "bacp-prom"
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) without (id)",
          "legendFormat": "heap sum",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"nonheap\"}) without (id)",
          "legendFormat": "nonheap sum",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Load average & open FDs",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "bacp-prom"
      },
      "targets": [
        {
          "expr": "system_load_average_1m",
          "legendFormat": "load1",
          "refId": "A"
        },
        {
          "expr": "process_files_open_files",
          "legendFormat": "open files",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefId",
              "options": "B"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Disk usable space (bacp_disk_free_bytes)",
      "description": "Custom gauge; -1 = poll failure. Thresholds for capacity planning.",
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 0,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "bacp-prom"
      },
      "targets": [
        {
          "expr": "bacp_disk_free_bytes",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1073741824
              },
              {
                "color": "green",
                "value": 5368709120
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdMarkers": true
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Tomcat global bytes (sent/received)",
      "description": "Embedded Tomcat metrics when exported; empty if unavailable.",
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 8,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "bacp-prom"
      },
      "targets": [
        {
          "expr": "rate(tomcat_global_sent_bytes_total[5m])",
          "legendFormat": "sent",
          "refId": "A"
        },
        {
          "expr": "rate(tomcat_global_received_bytes_total[5m])",
          "legendFormat": "received",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "Heap used / max (ratio)",
      "description": "Aligns with BacpJvmHeapUsageHigh alert (~0.88).",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "datasource": {
        "type": "prometheus",
        "uid": "bacp-prom"
      },
      "targets": [
        {
          "expr": "(\n  sum without (id) (jvm_memory_used_bytes{area=\"heap\"})\n  /\n  clamp_min(\n    sum without (id) (\n      (jvm_memory_max_bytes{area=\"heap\"} > bool 0) * jvm_memory_max_bytes{area=\"heap\"}\n    ),\n    1\n  )\n)",
          "legendFormat": "heap_ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.85
              },
              {
                "color": "red",
                "value": 0.92
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdMarkers": true
      }
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "JVM heap used (by pool)",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 43
      },
      "datasource": {
        "type": "prometheus",
        "uid": "bacp-prom"
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
